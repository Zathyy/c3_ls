module dessert::format::xml;
import dessert::ser;
import dessert::des;
import std::collections::list;

faultdef XML_ATTRIBUTE_AFTER_FIELD, XML_SLICE_IN_ATTRIBUTE;

struct XMLSerializer (Serializer) {
  DString output;
  List{String} current_field;
  bool attribute_mode;
}

fn XMLSerializer serializer() {
  return {};
}

fn void? XMLSerializer.serialize_null(&self) @dynamic {
  self.output.append("null");
}

fn void? XMLSerializer.serialize_bool(&self, bool b) @dynamic {
  self.output.append(b ? "true" : "false");
}

fn void? XMLSerializer.serialize_long(&self, long i) @dynamic {
  self.output.append(string::tformat("%s", i));
}

fn void? XMLSerializer.serialize_double(&self, double f) @dynamic {
  self.output.append(string::tformat("%s", f));
}

fn void? XMLSerializer.serialize_string(&self, String s) @dynamic {
  self.output.append(s);
}

fn void? XMLSerializer.struct_start(&self, String name) @dynamic {
  self.output.append("<");
  self.output.append(name.to_lower_copy(tmem));
  self.attribute_mode = true;
}

fn void? XMLSerializer.struct_end(&self, String name) @dynamic {
  self.output.append("</");
  self.output.append(name.to_lower_copy(tmem));
  self.output.append(">");
}

fn void? XMLSerializer.serialize_slice_start(&self, long len) @dynamic {}
fn void? XMLSerializer.serialize_slice_end(&self, long len) @dynamic {}

fn void? XMLSerializer.serialize_slice_item_start(&self, usz idx) @dynamic {
  String name = self.current_field[^1] ?: "el";
  if (name.ends_with("s")) {
    name = name[..^2];
  }
  self.output.append("<");
  self.output.append(name);
  self.output.append(">");
}
fn void? XMLSerializer.serialize_slice_item_end(&self, usz idx) @dynamic {
  String name = self.current_field[^1] ?: "el";
  if (name.ends_with("s")) {
    name = name[..^2];
  }
  self.output.append("</");
  self.output.append(name);
  self.output.append(">");
}

<* 
  Fields that start with @ will be serialized as attributes
*>
fn void? XMLSerializer.serialize_field_start(&self, String name, FieldAttrs fmt) @dynamic {
  if (try attr = fmt.get("xml:attribute") && attr == "true") {
    if (self.attribute_mode) {
      self.output.append(" ");
      self.output.append(name);
      self.output.append("=\"");
      return;
    } else {
      return XML_ATTRIBUTE_AFTER_FIELD~;
    }
  }

  if (self.attribute_mode) {
    self.output.append(">");
    self.attribute_mode = false;
  }
  self.output.append("<");
  self.output.append(name);
  self.output.append(">");
  self.current_field.push(name);
}

fn void? XMLSerializer.serialize_field_end(&self, String name, FieldAttrs fmt) @dynamic {
  if (self.attribute_mode) {
    self.output.append("\"");
  } else {
    self.output.append("</");
    self.output.append(name);
    self.output.append(">");
    (void)self.current_field.pop();
  }
}

fn String XMLSerializer.result(&self) => self.output.str_view();

// pretty_string formatter. Generated by Claude
fn String pretty_string(String xml, int indent_size = 2) {
  DString result;
  int depth = 0;
  usz i = 0;

  while (i < xml.len) {
    if (xml[i] != '<') {
      i++;
      continue;
    }

    usz tag_start = i;
    i++;
    while (i < xml.len && xml[i] != '>') i++;
    if (i >= xml.len) break;
    i++;
    String tag = xml[tag_start..i - 1];

    if (tag.len >= 2 && tag[1] == '/') {
      if (depth > 0) depth--;
      for (int k = 0; k < depth * indent_size; k++) result.append_char(' ');
      result.append(tag);
      result.append_char('\n');
    } else if (tag.len >= 2 && (tag[1] == '?' || tag[1] == '!')) {
      for (int k = 0; k < depth * indent_size; k++) result.append_char(' ');
      result.append(tag);
      result.append_char('\n');
    } else if (tag.len >= 2 && tag[tag.len - 2] == '/') {
      for (int k = 0; k < depth * indent_size; k++) result.append_char(' ');
      result.append(tag);
      result.append_char('\n');
    } else {
      // Look ahead: inline text content followed by closing tag?
      usz j = i;
      while (j < xml.len && xml[j] != '<') j++;

      if (j > i && j + 1 < xml.len && xml[j + 1] == '/') {
        String text = xml[i..j - 1];
        usz ts = 0;
        while (ts < text.len && (text[ts] == ' ' || text[ts] == '\t' || text[ts] == '\n' || text[ts] == '\r')) ts++;
        usz te = text.len;
        while (te > ts && (text[te - 1] == ' ' || text[te - 1] == '\t' || text[te - 1] == '\n' || text[te - 1] == '\r')) te--;

        if (ts < te) {
          String trimmed = text[ts..te - 1];
          usz k = j;
          while (k < xml.len && xml[k] != '>') k++;
          if (k >= xml.len) break;
          k++;

          for (int m = 0; m < depth * indent_size; m++) result.append_char(' ');
          result.append(tag);
          result.append(trimmed);
          result.append(xml[j..k - 1]);
          result.append_char('\n');
          i = k;
          continue;
        }
      }

      for (int k = 0; k < depth * indent_size; k++) result.append_char(' ');
      result.append(tag);
      result.append_char('\n');
      depth++;
    }
  }

  return result.str_view();
}

